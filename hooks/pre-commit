#!/usr/bin/env bash
# Global pre-commit hook — installed by setup.sh
# Delegates to per-repo scripts/run-tests.sh and runs global checks.
# Each check exits gracefully (0) if the tool is not installed.
# Only exits non-zero on actual check failures.
set -euo pipefail

# Step 1 — Find repo root
REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
if [ -z "$REPO_ROOT" ]; then
  exit 0  # Not in a git repo — nothing to check
fi

# Step 2 — Per-repo test script
if [ -x "$REPO_ROOT/scripts/run-tests.sh" ]; then
  "$REPO_ROOT/scripts/run-tests.sh" || {
    echo "Pre-commit: scripts/run-tests.sh failed. Fix errors before committing." >&2
    exit 1
  }
fi

# Step 3 — Lint (skip if tool not installed)

# ESLint — run if a config file exists and npx is available
if [ -f "$REPO_ROOT/.eslintrc" ] || [ -f "$REPO_ROOT/.eslintrc.js" ] || [ -f "$REPO_ROOT/.eslintrc.json" ] || [ -f "$REPO_ROOT/eslint.config.js" ]; then
  if command -v npx >/dev/null 2>&1; then
    npx eslint --quiet . || {
      echo "Pre-commit: ESLint failed." >&2
      exit 1
    }
  fi
fi

# ruff — run if a config file exists and ruff is available
if [ -f "$REPO_ROOT/pyproject.toml" ] || [ -f "$REPO_ROOT/ruff.toml" ]; then
  if command -v ruff >/dev/null 2>&1; then
    ruff check . || {
      echo "Pre-commit: ruff check failed." >&2
      exit 1
    }
  fi
fi

# Step 4 — Secret scanning (skip if gitleaks not installed)
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --no-banner || {
    echo "Pre-commit: gitleaks detected potential secrets. Review staged changes." >&2
    exit 1
  }
fi

# Step 5 — Plan-staleness check (Task 14 of workflow-doc-process-rework)
# When an active plan is set and a staged file falls within the plan's scope
# (i.e., a path mentioned in the plan.md), require the plan.md itself to
# also be staged. Use `git commit --no-verify` to bypass all pre-commit checks (including this one) — git-manager prohibits using --no-verify, but a human invoking git directly can use it.
ACTIVE_PLAN_FILE="$REPO_ROOT/.claude/active-plan"
if [ -f "$ACTIVE_PLAN_FILE" ]; then
  ACTIVE_PLAN_PATH=$(head -n1 "$ACTIVE_PLAN_FILE" | tr -d '[:space:]\r')
  PLAN_MD="$REPO_ROOT/$ACTIVE_PLAN_PATH"
  if [ -n "$ACTIVE_PLAN_PATH" ] && [ -f "$PLAN_MD" ]; then
    # Extract backtick-quoted paths (must contain a slash), drop placeholders
    PLAN_PATHS=$(grep -oE '`[a-zA-Z0-9_./-]+/[a-zA-Z0-9_.-]+`' "$PLAN_MD" 2>/dev/null \
      | tr -d '`' \
      | grep -vE '<|>' \
      | sort -u || true)
    STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null | sort -u || true)
    INTERSECTION=""
    if [ -n "$PLAN_PATHS" ] && [ -n "$STAGED_FILES" ]; then
      while IFS= read -r path; do
        [ -z "$path" ] && continue
        if echo "$STAGED_FILES" | grep -qxF "$path"; then
          INTERSECTION+="$path"$'\n'
        fi
      done <<< "$PLAN_PATHS"
    fi
    if [ -n "$INTERSECTION" ]; then
      if ! echo "$STAGED_FILES" | grep -qxF "$ACTIVE_PLAN_PATH"; then
        echo "Pre-commit: in-scope plan commit detected." >&2
        echo "  Active plan: $ACTIVE_PLAN_PATH" >&2
        echo "  In-scope staged files:" >&2
        printf '%s' "$INTERSECTION" | sed 's/^/    /' >&2
        echo "" >&2
        echo "  Update the plan via plan-management:divergence and stage it" >&2
        echo "  (use 'git add -f $ACTIVE_PLAN_PATH' if plans/ is gitignored)," >&2
        echo "  or run 'git commit --no-verify' to bypass all pre-commit checks (including this one) — git-manager prohibits using --no-verify, but a human invoking git directly can use it." >&2
        exit 1
      fi
    fi
  fi
fi

exit 0
